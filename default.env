ENV_VERSION=1

# Local-dev overlay. Production inventory overrides this to
# "adi.yml:ext-network.yml" (Traefik path, no localhost binding).
COMPOSE_FILE=adi.yml:rpc-shared.yml

PROJECT_NAME=adi

# Network: mainnet (testnet not currently supported in this repo)
NETWORK=mainnet

# ADI mainnet chain ID = 36900 = 0x9024
CHAIN_ID=36900

# =============================================================================
# Docker images — pin versioned tags, never use latest
# =============================================================================

# External node — matches EN_VERSION in upstream docker-compose.mainnet.yml
NODE_DOCKER_REPO=harbor.sre.ideasoft.io/adi-chain/external-node
NODE_DOCKER_TAG=v0.13.0-b1

# Proof-sync sidecar (upstream uses :latest; we pin). Same container also
# bootstraps the chain data dirs at startup, so no separate init container.
AZCOPY_DOCKER_REPO=peterdavehello/azcopy
AZCOPY_DOCKER_TAG=10.27.1

# =============================================================================
# Ports
# =============================================================================

# JSON-RPC HTTP + WebSocket (ADI multiplexes both on a single port)
RPC_PORT=3050
# Status / health server
STATUS_PORT=3071
# Sequencer block replay server
REPLAY_PORT=3054
# Prometheus metrics
METRICS_PORT=3312

# =============================================================================
# ADI configuration
# =============================================================================

# Required: archive Ethereum L1 RPC. Pruned L1 panics with
# "state at block is pruned". Set per host in ansible inventory.
GENERAL_L1_RPC_URL=

# Upstream replay/download endpoint
REPLAY_DOWNLOAD_URL=https://replay.adifoundation.ai
# Upstream main-node JSON-RPC. Used by the external node as its upstream
# (`general_main_node_rpc_url`) and by `check_sync.sh` as the reference RPC
# to compare local block height against — for ADI these are the same URL.
MAIN_RPC_URL=https://rpc.adifoundation.ai

# Genesis-derived contract addresses (do not change unless ADI rotates them)
BRIDGEHUB_ADDRESS=0x7a38c18a229ef8a0ae7104ba272a46280f2d59cb
BYTECODE_SUPPLIER_ADDRESS=0x6e369e616dd5a5cb0cd410f541c784033de89042

# Azure Blob shared proofs
PROOF_STORAGE_URL=https://adimainnet.blob.core.windows.net/proofs
PROOF_SYNC_INTERVAL=60
PROOF_SYNC_DELETE=false

# Rust log filter (rolled up by external-node)
RUST_LOG=info,zksync_os_server=info,zksync_os_sequencer=info,zksync_os_merkle_tree=info,zksync_os_priority_tree=info,zksync_os_server::prover_api=info

# =============================================================================
# Traefik / Prometheus integration
# =============================================================================

DOCKER_EXT_NETWORK=traefik_default
DOMAIN=cryptomanufaktur.net
RPC_HOST=adi
RPC_LB=adi-lb
WS_HOST=adiws
WS_LB=adiws-lb

# =============================================================================
# Pinning
# =============================================================================

SCRIPT_TAG=
