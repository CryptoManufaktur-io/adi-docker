# =============================================================================
# ADI Docker - Default Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.
# Variables ending in _TAG, _REPO, or _DOCKERFILE are "build targets"
# that get reset during updates when --refresh-targets is used.
# =============================================================================

# Environment version - increment when adding/renaming variables
ENV_VERSION=2

# Compose files to use (colon-separated)
# rpc-shared.yml exposes RPC/status/metrics on localhost for health checks.
# Add :ext-network.yml for Traefik/Prometheus integration.
COMPOSE_FILE=adi.yml:rpc-shared.yml

# Project name - used for container naming and Docker volume prefixes
PROJECT_NAME=adi

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# ADI mainnet is chain ID 36900 (0x9024)
NETWORK=mainnet
CHAIN_ID=36900
EXPECTED_CHAIN_ID=0x9024

# Public reference endpoint for verification
PUBLIC_RPC=https://rpc.adifoundation.ai
MAIN_RPC_URL=https://rpc.adifoundation.ai

# Required Ethereum L1 archive RPC endpoint. Production inventory should set
# this per host, usually to the local eth-main endpoint in the same region.
GENERAL_L1_RPC_URL=

# =============================================================================
# DOCKER IMAGES
# =============================================================================

# ADI external node image. Upstream setup repo pins v0.13.0-b1 for mainnet.
NODE_DOCKER_REPO=harbor.sre.ideasoft.io/adi-chain/external-node
NODE_DOCKER_TAG=v0.13.0-b1

# Proof sync sidecar. Pin the tag instead of using upstream's latest.
AZCOPY_DOCKER_REPO=peterdavehello/azcopy
AZCOPY_DOCKER_TAG=10.27.1

# =============================================================================
# DATA STORAGE
# =============================================================================

# Host data directory for node state and shared proof storage.
DATA_DIR=./mainnet_data

# Azure Blob proof storage used by the proof-sync sidecar.
PROOF_STORAGE_URL=https://adimainnet.blob.core.windows.net/proofs
PROOF_SYNC_INTERVAL=60
PROOF_SYNC_DELETE=false

# =============================================================================
# PORTS
# =============================================================================

# ADI uses one JSON-RPC port for both HTTP and WebSocket traffic.
RPC_PORT=3050
WS_PORT=3050

# External node block replay, status, and Prometheus ports.
REPLAY_PORT=3054
STATUS_PORT=3071
METRICS_PORT=3312

# =============================================================================
# LOGGING
# =============================================================================

RUST_LOG=info,zksync_os_server=info,zksync_os_sequencer=info,zksync_os_merkle_tree=info,zksync_os_priority_tree=info,zksync_os_server::prover_api=info

# =============================================================================
# TRAEFIK/PROMETHEUS INTEGRATION
# =============================================================================

# External Docker network name for reverse proxy / monitoring
DOCKER_EXT_NETWORK=traefik_default

# Secure web proxy hostnames (used with Traefik labels)
DOMAIN=example.com
RPC_HOST=adi
RPC_LB=adi-lb
WS_HOST=adiws
WS_LB=adiws-lb

# =============================================================================
# VERSION PINNING
# =============================================================================

# Pin this repo to a specific git tag (leave empty for latest main)
SCRIPT_TAG=
